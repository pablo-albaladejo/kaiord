echo "🏗️  Running build before commit..."

# Build all packages
pnpm build

# Check exit code
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Build failed! Commit blocked."
  echo ""
  echo "Fix the build errors and try again."
  echo ""
  echo "To skip this check (NOT RECOMMENDED):"
  echo "  git commit --no-verify"
  exit 1
fi

echo "✅ Build passed!"
echo ""
echo "🔍 Running TypeScript type check..."

# Type check all packages
pnpm -r exec tsc --noEmit

# Check exit code
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ TypeScript type check failed! Commit blocked."
  echo ""
  echo "Fix the type errors and try again."
  echo ""
  echo "To skip this check (NOT RECOMMENDED):"
  echo "  git commit --no-verify"
  exit 1
fi

echo "✅ Type check passed!"
echo ""
echo "🧪 Running tests before commit..."

# Run all tests in the monorepo
pnpm test

# Check exit code
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Tests failed! Commit blocked."
  echo ""
  echo "Fix the failing tests and try again:"
  echo "  pnpm test:watch"
  echo ""
  echo "To skip this check (NOT RECOMMENDED):"
  echo "  git commit --no-verify"
  exit 1
fi

echo "✅ All tests passed!"
echo ""
echo "🧪 Running scripts/ unit tests..."

# Run node:test for scripts/*.test.mjs (archive invariants, etc.)
pnpm test:scripts

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ scripts/ tests failed! Commit blocked."
  echo ""
  echo "Fix the failing tests:"
  echo "  pnpm test:scripts"
  echo ""
  echo "To skip this check (NOT RECOMMENDED):"
  echo "  git commit --no-verify"
  exit 1
fi

echo "✅ scripts/ tests passed!"
