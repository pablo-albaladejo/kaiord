# Run lint:fix before pushing
echo "🔍 Running lint:fix before push..."
pnpm lint:fix

# Check if lint:fix made any changes
if [ -n "$(git status --porcelain)" ]; then
  echo "❌ Lint fixes were applied. Please review and commit them:"
  git status --short
  echo ""
  echo "Run: git add . && git commit -m 'chore: apply lint fixes'"
  exit 1
else
  echo "✅ Lint check passed!"
fi
echo ""
echo "🔍 Running TypeScript type check..."

# Type check all packages — serially (see .husky/pre-commit comment;
# avoids transient tsc worker failures under concurrent load).
pnpm -r --workspace-concurrency=1 exec tsc --noEmit

# Check exit code
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ TypeScript type check failed! Push blocked."
  echo ""
  echo "Fix the type errors and try again."
  exit 1
fi

echo "✅ Type check passed!"
