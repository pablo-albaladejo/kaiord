# Verify lint before pushing (read-only — does NOT write to the working tree).
echo "🔍 Running lint check before push..."
pnpm lint

# Check exit code — fail the push if lint reports any errors.
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Lint check failed! Push blocked."
  echo ""
  echo "Run 'pnpm lint:fix' yourself to apply auto-fixes, review the changes,"
  echo "then commit them and retry the push."
  exit 1
fi

echo "✅ Lint check passed!"
echo ""
echo "🔍 Running TypeScript type check..."

# Type check all packages — serially (see .husky/pre-commit comment;
# avoids transient tsc worker failures under concurrent load).
pnpm -r --workspace-concurrency=1 exec tsc --noEmit

# Check exit code
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ TypeScript type check failed! Push blocked."
  echo ""
  echo "Fix the type errors and try again."
  exit 1
fi

echo "✅ Type check passed!"
