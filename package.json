{
  "name": "kaiord",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Open-source health & fitness data framework",
  "repository": {
    "type": "git",
    "url": "https://github.com/pablo-albaladejo/kaiord.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "js-yaml": "3.14.2",
      "lodash@<4.17.23": ">=4.17.23",
      "esbuild@<=0.24.2": ">=0.27.0",
      "glob@>=10.3.7 <=11.0.3": ">=11.1.0",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "qs@>=6.7.0 <=6.15.1": ">=6.15.2",
      "undici@<6.23.0": ">=6.23.0",
      "ajv@>=8.0.0 <8.18.0": ">=8.18.0",
      "hono@<4.12.25": ">=4.12.25",
      "@hono/node-server@<1.19.13": ">=1.19.13",
      "fast-uri@<3.1.2": ">=3.1.2",
      "ip-address@<10.1.1": ">=10.1.1",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "minimatch@<3.1.4": ">=3.1.4",
      "fast-xml-parser@<5.5.6": ">=5.5.6",
      "flatted@<3.4.2": ">=3.4.2",
      "undici@>=7.0.0 <7.24.0": "7.24.0",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "express-rate-limit@<8.2.2": ">=8.2.2",
      "smol-toml@<1.6.1": ">=1.6.1",
      "brace-expansion@>=4.0.0 <5.0.6": ">=5.0.6",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "vite": "^8.0.5"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@codecov/vite-plugin>vite": "8",
        "vitepress>vite": "8",
        "vitepress>@vitejs/plugin-vue>vite": "8",
        "@vitejs/plugin-vue>vite": "8"
      }
    }
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test && pnpm test:scripts",
    "lint": "pnpm lint:parallel && pnpm lint:post",
    "lint:parallel": "npm-run-all2 -p --max-parallel=4 --aggregate-output lint:packages lint:archive lint:specs lint:tsup-watchdog lint:mapper-no-tests lint:converter-has-tests lint:husky-no-bypass lint:package-deps lint:architecture lint:no-unconditional-skip lint:no-library-dual-mount lint:allowlists-empty lint:icons-distinct lint:build-portable lint:ci-fanout lint:scripts-orphans lint:workflow-timeouts lint:overrides-stale lint:session-match-id-shape lint:ai-sdk-containment",
    "lint:post": "npm-run-all2 -s lint:archive-index lint:archive-followups lint:specs-inventory",
    "lint:fix": "pnpm -r lint:fix && prettier --write .",
    "lint:packages": "pnpm -r lint",
    "lint:archive": "node scripts/check-archive-dates.mjs",
    "lint:archive-index": "node scripts/check-archive-index.mjs",
    "lint:archive-followups": "node scripts/check-archive-followups.mjs",
    "lint:specs-inventory": "node scripts/check-specs-inventory.mjs",
    "lint:specs": "node --test scripts/check-spec-format.test.mjs && node scripts/check-spec-format.mjs && pnpm exec openspec validate --specs",
    "lint:tsup-watchdog": "node scripts/check-tsup-ignoredeprecations.mjs",
    "lint:mapper-no-tests": "node scripts/check-mapper-no-tests.mjs",
    "lint:converter-has-tests": "node scripts/check-converter-has-tests.mjs",
    "lint:husky-no-bypass": "node scripts/check-husky-no-bypass-hint.mjs",
    "lint:package-deps": "node scripts/check-package-deps.mjs",
    "lint:architecture": "node scripts/check-architecture.mjs",
    "lint:no-unconditional-skip": "node scripts/check-no-unconditional-skip.mjs",
    "lint:no-library-dual-mount": "node scripts/check-no-library-dual-mount.mjs",
    "lint:allowlists-empty": "node scripts/check-allowlists-empty.mjs",
    "lint:icons-distinct": "node scripts/check-extension-icons-distinct.mjs",
    "lint:build-portable": "node scripts/check-build-portable.mjs",
    "lint:ci-fanout": "node scripts/check-ci-fanout-invariants.mjs",
    "lint:scripts-orphans": "node scripts/check-scripts-orphans.mjs",
    "lint:workflow-timeouts": "node scripts/check-workflow-timeouts.mjs",
    "lint:overrides-stale": "node scripts/check-overrides-stale.mjs",
    "lint:session-match-id-shape": "node scripts/check-session-match-id-shape.mjs",
    "lint:ai-sdk-containment": "node scripts/check-ai-sdk-containment.mjs",
    "lint:links": "bash scripts/lint-links.sh",
    "icons:build": "node scripts/build-extension-icons.mjs",
    "popup:sync": "node scripts/sync-popup-css.mjs",
    "test:scripts": "node --test scripts/*.test.mjs scripts/cws-api/*.test.mjs scripts/eslint-rules/*.test.mjs",
    "archive:index": "node scripts/generate-archive-index.mjs",
    "specs:inventory": "node scripts/generate-specs-inventory.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -r clean",
    "prepare": "husky",
    "arch:check": "depcruise packages/*/src --config .dependency-cruiser.cjs",
    "dead-code": "knip",
    "size": "size-limit",
    "duplication": "jscpd packages/*/src",
    "metrics": "node .github/scripts/collect-metrics.js",
    "metrics:compare": "node .github/scripts/compare-metrics.js"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@fission-ai/openspec": "^1.5.0",
    "@resvg/resvg-js": "^2.6.2",
    "@size-limit/esbuild": "^12.1.0",
    "@size-limit/file": "^12.1.0",
    "@types/node": "^26.1.0",
    "@vitest/eslint-plugin": "^1.6.20",
    "dependency-cruiser": "^18.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "jscpd": "^5.0.11",
    "knip": "^6.24.0",
    "lint-staged": "^17.0.8",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.4",
    "sharp": "^0.35.3",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "yaml": "^2.9.0"
  }
}
