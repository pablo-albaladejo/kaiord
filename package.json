{
  "name": "kaiord",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Open-source health & fitness data framework",
  "repository": {
    "type": "git",
    "url": "https://github.com/pablo-albaladejo/kaiord.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "js-yaml": "3.14.2",
      "lodash@<4.17.23": ">=4.17.23",
      "esbuild@<=0.24.2": ">=0.25.0",
      "glob@>=10.3.7 <=11.0.3": ">=11.1.0",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "undici@<6.23.0": ">=6.23.0",
      "ajv@>=8.0.0 <8.18.0": ">=8.18.0",
      "hono@<4.12.2": ">=4.12.2",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "minimatch@<3.1.4": ">=3.1.4",
      "fast-xml-parser@<5.5.6": ">=5.5.6",
      "flatted@<3.4.2": ">=3.4.2",
      "undici@>=7.0.0 <7.24.0": "7.24.0",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "express-rate-limit@<8.2.2": ">=8.2.2"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@codecov/vite-plugin>vite": "7"
      }
    }
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix && prettier --write .",
    "lint:packages": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -r clean",
    "setup:npm": "./scripts/quick-setup-npm.sh",
    "setup:npm:full": "./scripts/setup-npm-publishing.sh",
    "prepare": "husky",
    "arch:check": "depcruise packages/*/src --config .dependency-cruiser.cjs",
    "dead-code": "knip",
    "size": "size-limit",
    "duplication": "jscpd packages/*/src",
    "metrics": "node .github/scripts/collect-metrics.js",
    "metrics:compare": "node .github/scripts/compare-metrics.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.15.0",
    "@fission-ai/openspec": "^1.2.0",
    "@size-limit/file": "^11.0.0",
    "@types/node": "^25.0.0",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^9.15.0",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.0",
    "knip": "^5.0.0",
    "prettier": "^3.8.1",
    "size-limit": "^11.0.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.0"
  }
}
