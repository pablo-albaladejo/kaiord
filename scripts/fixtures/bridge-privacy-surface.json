{
  "garmin-bridge": {
    "manifest": {
      "permissions": [
        "storage",
        "tabs",
        "webRequest",
        "scripting"
      ],
      "host_permissions": [
        "https://connect.garmin.com/*"
      ],
      "content_scripts_matches": [
        [
          "https://connect.garmin.com/*"
        ],
        [
          "https://*.kaiord.com/*",
          "http://localhost/*"
        ]
      ],
      "externally_connectable_matches": [
        "http://localhost:5173/*",
        "http://localhost:5174/*",
        "https://*.kaiord.com/*"
      ]
    },
    "manifest_prod": {
      "permissions": [
        "storage",
        "tabs",
        "webRequest",
        "scripting"
      ],
      "host_permissions": [
        "https://connect.garmin.com/*"
      ],
      "content_scripts_matches": [
        [
          "https://connect.garmin.com/*"
        ],
        [
          "https://*.kaiord.com/*"
        ]
      ],
      "externally_connectable_matches": [
        "https://*.kaiord.com/*"
      ]
    },
    "allowed_paths": [
      {
        "method": "GET",
        "pattern": "^\\/workout-service\\/workouts(\\?.*)?$"
      },
      {
        "method": "POST",
        "pattern": "^\\/workout-service\\/workout$"
      }
    ]
  },
  "train2go-bridge": {
    "manifest": {
      "permissions": [
        "tabs",
        "storage",
        "scripting"
      ],
      "host_permissions": [
        "https://app.train2go.com/*"
      ],
      "content_scripts_matches": [
        [
          "https://app.train2go.com/*"
        ],
        [
          "https://*.kaiord.com/*",
          "http://localhost/*"
        ]
      ],
      "externally_connectable_matches": [
        "http://localhost:5173/*",
        "http://localhost:5174/*",
        "https://*.kaiord.com/*"
      ]
    },
    "manifest_prod": {
      "permissions": [
        "tabs",
        "storage",
        "scripting"
      ],
      "host_permissions": [
        "https://app.train2go.com/*"
      ],
      "content_scripts_matches": [
        [
          "https://app.train2go.com/*"
        ],
        [
          "https://*.kaiord.com/*"
        ]
      ],
      "externally_connectable_matches": [
        "https://*.kaiord.com/*"
      ]
    },
    "allowed_paths": [
      {
        "method": "GET",
        "pattern": "^\\/api\\/v2\\/profile\\/ping$"
      },
      {
        "method": "GET",
        "pattern": "^\\/api\\/v2\\/workplan\\/weekly\\/\\d{4}-\\d{2}-\\d{2}(\\?user=\\d+(&source=\\w+)?)?$"
      },
      {
        "method": "GET",
        "pattern": "^\\/api\\/v2\\/workplan\\/daily\\/\\d{4}-\\d{2}-\\d{2}(\\?user=\\d+(&source=\\w+)?)?$"
      },
      {
        "method": "GET",
        "pattern": "^\\/api\\/v2\\/workplan\\/tooltip\\/activity\\/\\d+$"
      },
      {
        "method": "GET",
        "pattern": "^\\/user\\/details$"
      }
    ]
  },
  "whoop-bridge": {
    "manifest": {
      "permissions": [
        "tabs",
        "webRequest",
        "scripting",
        "storage"
      ],
      "host_permissions": [
        "https://api.prod.whoop.com/*",
        "https://app.whoop.com/*"
      ],
      "content_scripts_matches": [
        [
          "https://app.whoop.com/*"
        ],
        [
          "https://app.whoop.com/*"
        ],
        [
          "https://*.kaiord.com/*",
          "http://localhost/*"
        ]
      ],
      "externally_connectable_matches": [
        "http://localhost:5173/*",
        "http://localhost:5174/*",
        "https://*.kaiord.com/*"
      ]
    },
    "manifest_prod": {
      "permissions": [
        "tabs",
        "webRequest",
        "scripting",
        "storage"
      ],
      "host_permissions": [
        "https://api.prod.whoop.com/*",
        "https://app.whoop.com/*"
      ],
      "content_scripts_matches": [
        [
          "https://app.whoop.com/*"
        ],
        [
          "https://app.whoop.com/*"
        ],
        [
          "https://*.kaiord.com/*"
        ]
      ],
      "externally_connectable_matches": [
        "https://*.kaiord.com/*"
      ]
    },
    "allowed_paths": []
  },
  "tanita-bridge": {
    "manifest": {
      "permissions": [
        "storage"
      ],
      "host_permissions": [
        "https://mytanita.eu/*"
      ],
      "content_scripts_matches": [
        [
          "https://*.kaiord.com/*",
          "http://localhost/*"
        ]
      ],
      "externally_connectable_matches": [
        "http://localhost:5173/*",
        "http://localhost:5174/*",
        "https://*.kaiord.com/*"
      ]
    },
    "manifest_prod": {
      "permissions": [
        "storage"
      ],
      "host_permissions": [
        "https://mytanita.eu/*"
      ],
      "content_scripts_matches": [
        [
          "https://*.kaiord.com/*"
        ]
      ],
      "externally_connectable_matches": [
        "https://*.kaiord.com/*"
      ]
    },
    "allowed_paths": [
      {
        "method": "GET",
        "pattern": "^\\/en\\/user\\/export-csv$"
      }
    ]
  }
}
