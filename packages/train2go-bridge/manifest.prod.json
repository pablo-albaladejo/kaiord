{
  "manifest_version": 3,
  "name": "Kaiord Train2Go Bridge",
  "version": "0.1.1",
  "description": "Reads training plans from Train2Go and bridges them to the Kaiord workout editor",

  "permissions": ["tabs"],

  "host_permissions": ["https://app.train2go.com/*"],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://app.train2go.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.kaiord.com/*"],
      "js": ["kaiord-announce.js"],
      "run_at": "document_start"
    }
  ],

  "externally_connectable": {
    "matches": ["https://*.kaiord.com/*"]
  }
}
