{
  "name": "@kaiord/landing",
  "private": true,
  "version": "4.1.2",
  "description": "Landing page for kaiord.com",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/build-locales.mjs",
    "i18n:extract": "node scripts/extract-strings.mjs",
    "preview": "vite preview",
    "test": "vitest --run",
    "lint:fix": "prettier --write src public index.html"
  },
  "dependencies": {
    "@kaiord/core": "workspace:*"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "jsdom": "^29.1.1",
    "node-html-parser": "^9.0.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
