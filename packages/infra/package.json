{
  "name": "@kaiord/infra",
  "version": "4.8.0",
  "private": true,
  "description": "Self-hostable AWS CDK stack for Kaiord Garmin proxy Lambda",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && eslint . && prettier --check src",
    "lint:fix": "eslint . --fix && prettier --write src",
    "cdk": "cdk",
    "deploy": "cdk deploy",
    "synth": "cdk synth",
    "clean": "rm -rf dist cdk.out",
    "dev:local": "tsx src/lambda/dev-server.ts"
  },
  "dependencies": {
    "@kaiord/core": "workspace:^",
    "@kaiord/garmin": "workspace:^",
    "@kaiord/garmin-connect": "workspace:^",
    "aws-cdk-lib": "^2.248.0",
    "constructs": "^10.6.0",
    "fetch-socks": "^1.3.3",
    "hono": "^4.12.11",
    "tailscale-lambda-extension": "https://github.com/pablo-albaladejo/tailscale-lambda-extension/releases/download/v0.1.3/tailscale-lambda-extension-0.1.3.tgz",
    "undici": "^8.0.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.12",
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "aws-cdk": "^2.1117.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pablo-albaladejo/kaiord.git",
    "directory": "packages/infra"
  },
  "author": "Kaiord Contributors",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
